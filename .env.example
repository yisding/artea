# Artea environment — copy to .env and change every secret before first boot.
# All version pins live here (ARCHITECTURE.md fixed contracts; never "latest").

# ---- image / package pins ----------------------------------------------------
# Keep GITEA_VERSION in sync with gitea/UPSTREAM (bump procedure lives there).
GITEA_VERSION=1.26.2
VERDACCIO_VERSION=6.7.2
NGINX_VERSION=1.30.2
DEVPI_SERVER_VERSION=6.20.2

# ---- namespace ---------------------------------------------------------------
# Private package namespace. This is both the Gitea org and the private npm scope
# (`@${ARTEA_NAMESPACE}`). Keep it lowercase and URL-safe.
ARTEA_NAMESPACE=artea

# ---- secrets (dev placeholders — change for any non-throwaway deployment) ----
# This example is a throwaway local smoke/e2e template, so placeholders are
# allowed by default. Set false after replacing every change-me-* value.
ARTEA_ALLOW_DEV_SECRETS=true
# Gitea bootstrap admin. Override if you need a different break-glass name.
ARTEA_ADMIN_USER=${ARTEA_NAMESPACE}-admin
ARTEA_ADMIN_PASSWORD=change-me-admin
# Demo user created by scripts/bootstrap.sh for e2e/smoke runs.
DEV1_PASSWORD=change-me-dev1
# devpi `root` password; also used by policy-sync to push constraints.
DEVPI_ROOT_PASSWORD=change-me-devpi
# HMAC secret of the Gitea push webhook on ${ARTEA_NAMESPACE}/registry-policy.
POLICY_WEBHOOK_SECRET=change-me-webhook

# Gitea PAT (read:repository) of the `svc-policy` service account — a regular
# non-admin user whose only access is read-only on the policy repo (via the
# `policy-readers` team). Minted by scripts/bootstrap.sh, which rewrites
# this line and recreates the policy-sync container; bootstrap also rotates an
# over-privileged (admin-minted) token away. Until then the service idles with
# failing syncs.
POLICY_SYNC_TOKEN=bootstrap-pending
