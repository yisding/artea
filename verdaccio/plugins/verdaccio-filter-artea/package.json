{
  "name": "verdaccio-filter-artea",
  "version": "0.1.0",
  "private": true,
  "description": "Verdaccio metadata filter + tarball middleware: blocks npm packages from npm-rules.yaml and applies shared upstream age policy, failing closed when policy is unavailable",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "semver": "^7.8.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "@types/semver": "^7.5.8",
    "@verdaccio/types": "^10.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  }
}
