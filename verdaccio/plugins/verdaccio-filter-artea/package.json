{
  "name": "verdaccio-filter-artea",
  "version": "0.1.0",
  "private": true,
  "description": "Verdaccio metadata filter + tarball middleware: blocks npm packages from npm-rules.yaml and applies shared upstream age policy, failing closed when policy is unavailable",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "js-yaml": "^5.2.0",
    "semver": "^7.8.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.1",
    "@types/semver": "^7.5.8",
    "@verdaccio/core": "^8.1.1",
    "@verdaccio/types": "^13.0.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
